# Contact form email delivery (SMTP)
# For Gmail, use smtp.gmail.com and an App Password (not your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email
SMTP_PASS=your_gmail_app_password

# Destination inbox for contact form messages
CONTACT_RECEIVER_EMAIL=your_email

# Optional MongoDB storage for contact submissions (recommended on Vercel)
MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=portfolio
MONGODB_COLLECTION=contacts
